{
    "name": "Document",
    "type": "object",
    "properties": {
      "operation_id": {
        "type": "string"
      },
      "dossier_reference": {
        "type": "string",
        "description": "Num\u00e9ro de dossier (r\u00e9f\u00e9rence op\u00e9ration, ex. OP-2024-0892)"
      },
      "type": {
        "type": "string",
        "enum": [
          "nota",
          "commercial_invoice",
          "cmr",
          "loading_sheet",
          "mrn",
          "t1",
          "salida",
          "eur1",
          "mlv",
          "bl",
          "invoice",
          "pod",
          "packing_list",
          "customs",
          "photo",
          "other"
        ],
        "default": "other"
      },
      "name": {
        "type": "string"
      },
      "file_url": {
        "type": "string"
      },
      "uploaded_by": {
        "type": "string"
      },
      "status": {
        "type": "string",
        "enum": [
          "pending",
          "validated",
          "rejected"
        ],
        "default": "pending"
      },
      "notes": {
        "type": "string"
      },
      "validated_by": {
        "type": "string",
        "description": "Nom de la personne ayant valid\u00e9 le document"
      },
      "validated_at": {
        "type": "string",
        "format": "date-time"
      },
      "rejected_by": {
        "type": "string"
      },
      "rejected_at": {
        "type": "string",
        "format": "date-time"
      }
    },
    "required": [
      "operation_id",
      "dossier_reference",
      "type",
      "name"
    ]
  }