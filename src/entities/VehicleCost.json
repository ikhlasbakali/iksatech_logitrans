{
    "name": "VehicleCost",
    "type": "object",
    "properties": {
      "vehicle_id": {
        "type": "string"
      },
      "vehicle_plate": {
        "type": "string"
      },
      "type": {
        "type": "string",
        "enum": [
          "fuel",
          "maintenance",
          "repair",
          "insurance",
          "tax",
          "toll",
          "fine",
          "other"
        ]
      },
      "date": {
        "type": "string",
        "format": "date"
      },
      "amount": {
        "type": "number"
      },
      "quantity": {
        "type": "number",
        "description": "Litres pour carburant, km pour p\u00e9age, etc."
      },
      "unit_price": {
        "type": "number"
      },
      "mileage_at_transaction": {
        "type": "number"
      },
      "supplier": {
        "type": "string"
      },
      "invoice_number": {
        "type": "string"
      },
      "notes": {
        "type": "string"
      }
    },
    "required": [
      "vehicle_id",
      "type",
      "date",
      "amount"
    ]
  }