{
    "name": "Incident",
    "type": "object",
    "properties": {
      "operation_id": {
        "type": "string"
      },
      "type": {
        "type": "string",
        "enum": [
          "delay",
          "damage",
          "accident",
          "breakdown",
          "missing_docs",
          "customer_complaint",
          "other"
        ],
        "default": "other"
      },
      "severity": {
        "type": "string",
        "enum": [
          "low",
          "medium",
          "high",
          "critical"
        ],
        "default": "medium"
      },
      "title": {
        "type": "string"
      },
      "description": {
        "type": "string"
      },
      "status": {
        "type": "string",
        "enum": [
          "open",
          "in_progress",
          "resolved",
          "closed"
        ],
        "default": "open"
      },
      "assigned_to": {
        "type": "string"
      },
      "resolution": {
        "type": "string"
      },
      "resolved_at": {
        "type": "string",
        "format": "date-time"
      },
      "reported_by": {
        "type": "string"
      }
    },
    "required": [
      "operation_id",
      "type",
      "title"
    ]
  }